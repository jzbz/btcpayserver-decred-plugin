@model BTCPayServer.Plugins.Decred.Controllers.DecredStoreViewModel
@{
    ViewData["Title"] = $"{Model.CryptoCode} Settings";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<div class="row">
    <div class="col-xl-8">

        @* Wallet status *@
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Wallet Status</h5>
            </div>
            <div class="card-body">
                @if (Model.WalletAvailable)
                {
                    <span class="badge bg-success">Available</span>
                    @if (Model.Synced)
                    {
                        <span class="text-muted">Synced at block @Model.WalletHeight</span>
                    }
                    else
                    {
                        <span class="text-warning">Syncing...</span>
                    }
                }
                else
                {
                    <span class="badge bg-danger">Unavailable</span>
                }
            </div>
        </div>

        @* Wallet actions *@
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Wallet</h5>
            </div>
            <div class="card-body">
                <a asp-controller="DecredLikeStore" asp-action="WalletSend"
                   asp-route-storeId="@Context.GetRouteValue("storeId")" asp-route-cryptoCode="@Model.CryptoCode"
                   class="btn btn-primary">Send</a>
            </div>
        </div>

        @* Payment method settings *@
        <form method="post" asp-antiforgery="true">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Payment Settings</h5>
                </div>
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input asp-for="Enabled" type="checkbox" class="form-check-input" />
                        <label asp-for="Enabled" class="form-check-label">Enable @Model.CryptoCode payments</label>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="AccountName" class="form-label">Account Name</label>
                        <input asp-for="AccountName" class="form-control" placeholder="default" />
                        <span class="text-muted small">The dcrwallet account to use for generating addresses.</span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="InvoiceSettledConfirmationThreshold" class="form-label">Confirmation Threshold</label>
                        <input asp-for="InvoiceSettledConfirmationThreshold" type="number" class="form-control" placeholder="Use store speed policy" min="0" />
                        <span class="text-muted small">
                            Number of confirmations required before a payment is considered settled.
                            Leave empty to use the store's default speed policy.
                        </span>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>
